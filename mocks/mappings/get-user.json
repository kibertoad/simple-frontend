{
  "name": "get-user - GET /users/{id}",
  "request": {
    "method": "GET",
    "urlPathPattern": "/users/[^/]+"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "transformers": ["response-template"],
    "jsonBody": {
      "user": { "id": "{{request.pathSegments.[1]}}" }
    }
  }
}
