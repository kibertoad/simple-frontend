{
  "name": "create-kenguroo (edge) - POST /kenguroos name=trigger-rate-limit -> 429",
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/kenguroos",
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.name", "equalTo": "trigger-rate-limit" } }
    ]
  },
  "response": {
    "status": 429,
    "headers": {
      "Content-Type": "application/json",
      "Retry-After": "5"
    },
    "bodyFileName": "error-rate-limit.json"
  }
}
