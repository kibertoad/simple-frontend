{
  "name": "create-kenguroo (edge) - POST /kenguroos name=trigger-error -> 500",
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/kenguroos",
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.name", "equalTo": "trigger-error" } }
    ]
  },
  "response": {
    "status": 500,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "error-server.json"
  }
}
