{
  "name": "kenguroos-get-by-id",
  "request": {
    "method": "GET",
    "urlPathPattern": "/kenguroos/[^/]+"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "transformers": ["response-template"],
    "jsonBody": {
      "kenguroo": {
        "id": "{{request.pathSegments.[1]}}",
        "name": "Joey",
        "age": 2
      }
    }
  }
}
