# Base URL of the simpler-service3 API.
# This is the default the app starts with; it can also be overridden at runtime
# in the UI (stored in localStorage).
VITE_API_BASE_URL=http://localhost:3000

# Target the Vite dev server proxies "/api" requests to. Use this to avoid CORS
# during development: set the runtime base URL in the UI to "/api" and requests
# are forwarded here by the dev server.
VITE_PROXY_TARGET=http://localhost:3000
